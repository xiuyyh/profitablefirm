rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges.
     * Uses a direct get call to the investorProfiles collection.
     */
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/investorProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLLECTION RULES ---

    match /investorProfiles/{investorId} {
      // Allow get/list if owner or admin
      allow get, list: if isOwner(investorId) || isAdmin();
      
      // Only user can create their own profile
      allow create: if isOwner(investorId);
      
      // Owner or admin can update
      allow update: if isOwner(investorId) || isAdmin();
      
      // Only admin can delete
      allow delete: if isAdmin();

      match /investments/{investmentId} {
        allow get, list: if isOwner(investorId) || isAdmin();
        allow create: if isOwner(investorId) || isAdmin();
        allow update, delete: if isOwner(investorId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(investorId) || isAdmin();
        allow create: if isOwner(investorId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // --- COLLECTION GROUP RULES ---
    
    // Explicit rule for collection group queries across the entire database
    // This allows admins to perform query(collectionGroup(db, "transactions"), ...)
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
      // Allow get for individual transaction lookup if admin
      allow get: if isAdmin();
    }
  }
}