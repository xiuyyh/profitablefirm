rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description Simplified "Test Mode" rules for development.
     * This allows any authenticated user to read and write to the database.
     * This resolves the 'Missing or insufficient permissions' errors encountered 
     * during the collectionGroup query for pending transactions.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}