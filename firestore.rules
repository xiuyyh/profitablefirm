rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    /**
     * @description TEST MODE PERMISSIONS
     * Allowing all authenticated users full access to all documents and collection groups.
     * This is intended to resolve permission errors during the index propagation and development phase.
     */
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}