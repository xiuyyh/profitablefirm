
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- HELPER FUNCTIONS ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the authenticated user has administrative privileges.
     * Simplified for better performance in collection group queries.
     */
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/investorProfiles/$(request.auth.uid)).data.role == 'admin';
    }

    // --- COLLECTION RULES ---

    match /investorProfiles/{investorId} {
      allow get: if isOwner(investorId) || isAdmin();
      allow list: if isAdmin() || isOwner(investorId);
      allow create: if isOwner(investorId);
      allow update: if isOwner(investorId) || isAdmin();
      allow delete: if isAdmin();

      match /investments/{investmentId} {
        allow get, list: if isOwner(investorId) || isAdmin();
        allow create: if isOwner(investorId) || isAdmin();
        allow update, delete: if isOwner(investorId) || isAdmin();
      }

      match /transactions/{transactionId} {
        allow get, list: if isOwner(investorId) || isAdmin();
        allow create: if isOwner(investorId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // --- COLLECTION GROUP RULES ---
    
    // Explicit rule for collection group queries across the entire database
    match /{path=**}/transactions/{transactionId} {
      allow list: if isAdmin();
    }
  }
}
